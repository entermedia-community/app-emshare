<page>
	<property name="eventname">Apply Informatics to Assets and Entities</property>
	<property name="eventdescription">Use AI to Add metadata (title, caption, description, alt, tags) automatically</property>

	<property name="delay">10m</property>
	
	<property name="enabled">true</property>

	<path-action name="AutomationModule.runScenerio" >
		<property name="automationscenario">informatics</property>
	</path-action>
	

</page>