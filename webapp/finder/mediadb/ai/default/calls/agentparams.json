{
	"model": "$!{model}",
	"messages": [
		{
			"role": "system",
			"content": "You are an assistant in an intelligent agent workflow. Your task is to analyze the result of the previous agent's execution and determine any necessary parameters for the next agent."
		},
		{
			"role": "user",
			"content": #jesc("
Previous Agent: $!{previousagent}
Previous Agent's Output: $!{previousoutput}
")
		}
	],
	"tools": [
		{
			"type": "function",
			"function": {
				"name": "$!{agentenabled.id}",
				"description": "$!{agentenabled.llmprompt}"
				#set($params = $agentenabled.getAgentParameterStructure())
				#if($params.size() > 0)
					,
					"parameters": {
						"type": "object",
						"properties": {
							#foreach($param in $params)
								#if($foreach.count>1)
								,
								#end
								"${param.id}": {
									"type": "${param.data_type}",
									"description": "${param.description}"
								}
							#end
						}
					}
				#end
			}
		}
	],
	"tool_choice": "required"
}
